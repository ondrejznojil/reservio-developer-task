{
    "name": "reservio/developer-task",
    "type": "project",
    "scripts": {
      "test": "phpunit"
    },
    "require": {
        "php": "^8.5",
        "cellar/tactician": "^1.10",
        "contributte/apitte": "^0.14.0",
        "illuminate/container": "^13.5",
        "illuminate/pipeline": "^13.5",
        "nette/bootstrap": "^3.2",
        "nette/di": "^3.2",
        "nettrine/migrations": "^0.10.1",
        "nettrine/orm": "^0.9.0",
        "ramsey/uuid": "^4.9",
        "rebing/graphql-laravel": "^9.17.0",
        "symfony/console": "^7.4",
        "tracy/tracy": "^2.10"
    },
    "require-dev": {
        "doctrine/data-fixtures": "^2.2",
        "phpunit/phpunit": "^11.4"
    },
    "autoload": {
        "files": [
            "src/helpers.php"
        ],
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
